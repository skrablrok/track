generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Role values: ADMIN, MANAGER, EMPLOYEE, FOREMAN
// ProjectStatus values: ACTIVE, COMPLETED, ON_HOLD
// CheckoutStatus values: ACTIVE, PENDING_RETURN, RETURNED, CONSUMED
// RequestStatus values: PENDING, APPROVED, PARTIALLY_APPROVED, REJECTED
// NotificationType values: REQUEST_SUBMITTED, REQUEST_REVIEWED, STOCK_LOW, STOCK_NEGATIVE
// ToolType values: TOOL, MATERIAL
// RequestItem.toolId is null for custom items not in inventory; itemName holds the free-text name in that case

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  password       String         @default("")
  name           String         @default("")
  role           String         @default("EMPLOYEE")
  active         Boolean        @default(true)
  setupComplete  Boolean        @default(true)
  inviteToken    String?        @unique
  inviteExpiry   DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  checkouts      Checkout[]
  auditLogs      AuditLog[]
  requests       Request[]
  notifications  Notification[]
  ledProjects    Project[]      @relation("ProjectForeman")
}

model Tool {
  id           String        @id @default(cuid())
  name         String
  description  String?
  category     String?
  imageUrl     String?
  type         String        @default("TOOL")
  totalStock   Int           @default(1)
  currentStock Int           @default(1)
  minStock     Int           @default(2)
  maxStock        Int                  @default(10)
  qrCode          String               @unique @default(cuid())
  active          Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  checkouts       Checkout[]
  requestItems    RequestItem[]
  warehouseStocks ToolWarehouseStock[]
}

model ToolWarehouseStock {
  id        String @id @default(cuid())
  toolId    String
  tool      Tool   @relation(fields: [toolId], references: [id], onDelete: Cascade)
  warehouse String
  quantity  Int    @default(0)

  @@unique([toolId, warehouse])
}

model Project {
  id          String     @id @default(cuid())
  name        String
  location    String?
  description String?
  status      String     @default("ACTIVE")
  foremanId   String?
  foreman     User?      @relation("ProjectForeman", fields: [foremanId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  checkouts   Checkout[]
  requests    Request[]
}

model Checkout {
  id           String    @id @default(cuid())
  toolId       String
  userId       String
  projectId    String?
  requestId    String?
  quantity     Int       @default(1)
  checkoutDate DateTime  @default(now())
  returnDate   DateTime?
  durationMins Int?
  notes        String?
  status       String    @default("ACTIVE")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tool         Tool      @relation(fields: [toolId], references: [id])
  user         User      @relation(fields: [userId], references: [id])
  project      Project?  @relation(fields: [projectId], references: [id])
}

model Request {
  id          String        @id @default(cuid())
  requesterId String
  projectId   String?
  status      String        @default("PENDING")
  notes       String?
  adminNotes  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  requester   User          @relation(fields: [requesterId], references: [id])
  project     Project?      @relation(fields: [projectId], references: [id])
  items       RequestItem[]
}

model RequestItem {
  id                   String    @id @default(cuid())
  requestId            String
  toolId               String?
  itemName             String?
  requestedQty         Int
  approvedQty          Int?
  notes                String?
  procurementStatus    String?
  procurementUpdatedAt DateTime?
  createdAt            DateTime  @default(now())
  request              Request   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  tool                 Tool?     @relation(fields: [toolId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  linkUrl   String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}
